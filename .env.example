# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_tracker

# JWT
JWT_SECRET=as
JWT_EXPIRES_IN=15m

# Encryption (for eToro token storage)
ENCRYPTION_KEY=test key

# eToro API
ETORO_API_BASE_URL=https://public-api.etoro.com/api/v1

# CORS
CORS_ORIGIN=http://localhost:8081
