# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio_tracker

# JWT
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=15m

# App access password (for the login screen)
APP_PASSWORD=your-app-password

# eToro API
ETORO_API_BASE_URL=https://public-api.etoro.com/api/v1
ETORO_API_KEY=your-etoro-api-key
ETORO_USER_KEY=your-etoro-user-key

# CORS
CORS_ORIGIN=http://localhost:8081
